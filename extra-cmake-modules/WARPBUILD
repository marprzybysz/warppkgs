pkgname=extra-cmake-modules
pkgver=6.7.0
description="Extra modules and scripts for CMake (required for KDE)"
arch=x86_64
license=BSD
deps=cmake
makedeps=cmake,ninja,python3
source=https://download.kde.org/stable/frameworks/6.7/extra-cmake-modules-6.7.0.tar.xz
sha256=VERIFY

build() {
    cmake -GNinja \
          -DCMAKE_INSTALL_PREFIX=/usr \
          -DCMAKE_BUILD_TYPE=Release \
          -DBUILD_TESTING=OFF \
          -B build
    ninja -C build $MAKEFLAGS
}

package() {
    DESTDIR="$DESTDIR" ninja -C build install
}
