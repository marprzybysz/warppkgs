pkgname=ghostty
pkgver=1.0.1
description="Fast, feature-rich, cross-platform terminal emulator"
arch=x86_64
license=MIT
deps=glibc,gtk4,libadwaita,freetype,fontconfig,harfbuzz,libxkbcommon,wayland,mesa,dbus,oniguruma
makedeps=zig,pkg-config,blueprint-compiler
source=https://github.com/ghostty-org/ghostty/archive/refs/tags/v1.0.1.tar.gz
sha256=VERIFY

build() {
    zig build \
        --prefix /usr \
        -Doptimize=ReleaseFast \
        -Dcpu=baseline \
        -Dpie=true
}

package() {
    zig build install \
        --prefix "$DESTDIR/usr" \
        -Doptimize=ReleaseFast \
        -Dcpu=baseline
}
