pkgname=itstool
pkgver=2.0.7
description="XML translation tool — makedep dla dokumentacji GNOME"
arch=x86_64
license=GPL-3.0
deps=glibc,python3,libxml2
makedeps=python3
source=https://files.itstool.org/itstool/itstool-2.0.7.tar.bz2
sha256=VERIFY

build() {
    ./configure --prefix=/usr
