pkgname=mutter
pkgver=47.1
description="GNOME compositor and window manager"
arch=x86_64
license=GPL-2.0
deps=glibc,glib,gtk4,libxkbcommon,wayland,libinput,libdrm,mesa,pango,cairo,dbus,elogind,at-spi2-core
makedeps=gcc,meson,ninja,pkg-config,python3,gobject-introspection,wayland-protocols
source=https://ftp.gnome.org/pub/gnome/sources/mutter/47/mutter-47.1.tar.xz
sha256=VERIFY

build() {
    meson setup build \
        --prefix=/usr \
        --buildtype=release \
        -Dtests=false \
        -Dprofiler=false \
        -Dintrospection=false \
        -Ddocs=false
    ninja -C build $MAKEFLAGS
}

package() {
    DESTDIR="$DESTDIR" ninja -C build install
}
