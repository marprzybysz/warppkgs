pkgname=ocaml
pkgver=5.2.1
description="OCaml — szybki funkcyjny język, używany w Jane Street (finanse) i Meta"
arch=x86_64
license=LGPL-2.1
deps=glibc
makedeps=gcc,make
source=https://github.com/ocaml/ocaml/archive/refs/tags/5.2.1.tar.gz
sha256=VERIFY

build() {
    ./configure --prefix=/usr
    make $MAKEFLAGS world.opt
}

package() {
    make DESTDIR="$DESTDIR" install
}
