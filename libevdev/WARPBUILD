pkgname=libevdev
pkgver=1.13.3
description="Kernel input event device library — wymagana przez libinput"
arch=x86_64
license=MIT
deps=glibc
makedeps=gcc,meson,ninja,pkg-config,python3
source=https://freedesktop.org/software/libevdev/libevdev-1.13.3.tar.xz
sha256=VERIFY

build() {
    meson setup build --prefix=/usr --buildtype=release -Dtests=disabled -Ddocumentation=disabled
    ninja -C build $MAKEFLAGS
}

package() {
    DESTDIR="$DESTDIR" ninja -C build install
}
