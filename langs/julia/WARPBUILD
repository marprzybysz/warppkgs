pkgname=julia
pkgver=1.11.2
description="Julia — naukowy, szybki jak C dla math/data science (pre-built)"
arch=x86_64
license=MIT
deps=glibc,libstdc++
makedeps=
source=https://julialang-s3.julialang.org/bin/linux/x64/1.11/julia-1.11.2-linux-x86_64.tar.gz
sha256=VERIFY

build() {
    :
}

package() {
    install -dm755 "$DESTDIR/usr/lib/julia"
    cp -r . "$DESTDIR/usr/lib/julia/"
    ln -sf /usr/lib/julia/bin/julia "$DESTDIR/usr/bin/julia"
}
