pkgname=libgpg-error
pkgver=1.51
description="GnuPG error codes library — wymagana przez gpgme i libassuan"
arch=x86_64
license=LGPL-2.1
deps=glibc
makedeps=gcc,make,autoconf,automake,gettext
source=https://gnupg.org/ftp/gcrypt/libgpg-error/libgpg-error-1.51.tar.bz2
sha256=VERIFY

build() {
    ./configure --prefix=/usr
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
