pkgname=lf
pkgver=r32
description="Terminal file manager napisany w Go — szybki, konfigurowalny vi-like"
arch=x86_64
license=MIT
deps=glibc
makedeps=go
source=https://github.com/gokcehan/lf/archive/refs/tags/r32.tar.gz
sha256=VERIFY

build() {
    go build -ldflags="-s -w" .
}

package() {
    install -Dm755 lf "$DESTDIR/usr/bin/lf"
}
