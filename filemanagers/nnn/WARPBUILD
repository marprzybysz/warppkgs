pkgname=nnn
pkgver=5.0
description="Minimalistyczny file manager TUI — najszybszy, działa wszędzie"
arch=x86_64
license=BSD
deps=glibc,ncurses,readline
makedeps=gcc,make,pkg-config
source=https://github.com/jarun/nnn/releases/download/v5.0/nnn-v5.0.tar.gz
sha256=VERIFY

build() {
    make $MAKEFLAGS O_NERD=1
}

package() {
    make PREFIX=/usr DESTDIR="$DESTDIR" install
}
