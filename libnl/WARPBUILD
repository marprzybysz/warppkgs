pkgname=libnl
pkgver=3.10.0
description="Netlink protocol library (dep NetworkManager)"
arch=x86_64
license=LGPL-2.1
deps=glibc
makedeps=gcc,make,autoconf,automake,libtool,bison,flex
source=https://github.com/thom311/libnl/releases/download/libnl3_10_0/libnl-3.10.0.tar.gz
sha256=VERIFY

build() {
    ./configure --prefix=/usr --disable-static
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
