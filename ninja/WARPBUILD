pkgname=ninja
pkgver=1.12.1
description="Small build system with a focus on speed"
arch=x86_64
license=Apache-2.0
deps=glibc,gcc-runtime
makedeps=gcc,g++,python3
source=https://github.com/ninja-build/ninja/archive/refs/tags/v1.12.1.tar.gz
sha256=

build() {
    python3 configure.py --bootstrap
}

package() {
    install -Dm755 ninja "$DESTDIR/usr/bin/ninja"
}
