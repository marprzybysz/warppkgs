pkgname=libxfixes
pkgver=6.0.1
description="X Fixes extension library"
arch=x86_64
license=MIT
deps=glibc,libx11
makedeps=gcc,make,pkg-config
source=https://xorg.freedesktop.org/releases/individual/lib/libXfixes-6.0.1.tar.xz
sha256=VERIFY

build() {
    ./configure --prefix=/usr --disable-static
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
