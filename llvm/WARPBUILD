pkgname=llvm
pkgver=19.1.0
description="LLVM compiler infrastructure — backend dla Crystal, D, Rust, clang (~100 SBU)"
arch=x86_64
license=Apache-2.0
deps=glibc,libffi,zlib,libxml2
makedeps=gcc,cmake,ninja,python3,pkg-config
source=https://github.com/llvm/llvm-project/releases/download/llvmorg-19.1.0/llvm-19.1.0.src.tar.xz
sha256=VERIFY

build() {
    cmake -B build -G Ninja \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr \
        -DLLVM_ENABLE_FFI=ON \
        -DLLVM_BUILD_LLVM_DYLIB=ON \
        -DLLVM_LINK_LLVM_DYLIB=ON \
        -DLLVM_TARGETS_TO_BUILD="X86"
    ninja -C build $MAKEFLAGS
}

package() {
    DESTDIR="$DESTDIR" ninja -C build install
}
