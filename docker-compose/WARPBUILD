pkgname=docker-compose
pkgver=2.30.0
description="Docker Compose v2 — definiowanie i uruchamianie multi-container aplikacji"
arch=x86_64
license=Apache-2.0
deps=glibc,docker
makedeps=go,make
source=https://github.com/docker/compose/archive/refs/tags/v2.30.0.tar.gz
sha256=VERIFY

build() {
    make $MAKEFLAGS
}

package() {
    install -Dm755 bin/build/docker-compose \
        "$DESTDIR/usr/libexec/docker/cli-plugins/docker-compose"
    ln -sf /usr/libexec/docker/cli-plugins/docker-compose \
        "$DESTDIR/usr/bin/docker-compose"
}
