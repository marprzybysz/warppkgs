pkgname=gperf
pkgver=3.1
description="GNU perfect hash function generator — makedep dla wielu projektów"
arch=x86_64
license=GPL-3.0
deps=glibc
makedeps=gcc,make
source=https://ftp.gnu.org/gnu/gperf/gperf-3.1.tar.gz
sha256=VERIFY

build() {
    ./configure --prefix=/usr
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
