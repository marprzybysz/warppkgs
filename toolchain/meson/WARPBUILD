pkgname=meson
pkgver=1.5.1
description="High-performance build system"
arch=any
license=Apache-2.0
deps=python3
makedeps=python3
source=https://github.com/mesonbuild/meson/releases/download/1.5.1/meson-1.5.1.tar.gz
sha256=

build() {
    true
}

package() {
    python3 -m installer --destdir="$DESTDIR" --prefix=/usr dist/*.whl 2>/dev/null || \
    pip3 install --root="$DESTDIR" --prefix=/usr --no-deps .
}
