pkgname=libxext
pkgver=1.3.6
description="X11 extensions library"
arch=x86_64
license=MIT
deps=glibc,libx11
makedeps=gcc,make,pkg-config
source=https://xorg.freedesktop.org/releases/individual/lib/libXext-1.3.6.tar.xz
sha256=VERIFY

build() {
    ./configure --prefix=/usr --disable-static
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
