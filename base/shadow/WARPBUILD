pkgname=shadow
pkgver=4.16.0
description="User and group account management tools"
arch=x86_64
license=BSD-3-Clause
deps=glibc,libxcrypt,acl,attr
makedeps=gcc,make
source=https://github.com/shadow-maint/shadow/releases/download/4.16.0/shadow-4.16.0.tar.xz
sha256=

build() {
    ./configure --prefix=/usr   \
                --sysconfdir=/etc \
                --disable-static \
                --with-libcrack=no
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
