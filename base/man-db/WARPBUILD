pkgname=man-db
pkgver=2.12.1
description="Man page viewer and database"
arch=x86_64
license=GPL-2.0
deps=glibc,groff,less,libpipeline,gdbm
makedeps=gcc,make,pkg-config
source=https://download.savannah.gnu.org/releases/man-db/man-db-2.12.1.tar.xz
sha256=

build() {
    ./configure --prefix=/usr          \
                --sysconfdir=/etc      \
                --disable-setuid       \
                --enable-cache-owner=bin \
                --with-browser=/usr/bin/lynx \
                --with-pager=/usr/bin/less
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
