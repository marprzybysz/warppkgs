pkgname=kbd
pkgver=2.6.4
description="Keyboard and console font tools"
arch=x86_64
license=GPL-2.0
deps=glibc
makedeps=gcc,make,pkg-config
source=https://www.kernel.org/pub/linux/utils/kbd/kbd-2.6.4.tar.xz
sha256=

build() {
    ./configure --prefix=/usr --disable-vlock
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
