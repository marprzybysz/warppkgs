pkgname=xf86-video-nouveau
pkgver=1.0.17
description="Xorg DDX driver for NVIDIA GPUs (nouveau open source)"
arch=x86_64
license=MIT
deps=glibc,xorg-server,libdrm,mesa
makedeps=gcc,make,pkg-config,autoconf,automake,libtool,xorg-server
source=https://xorg.freedesktop.org/releases/individual/driver/xf86-video-nouveau-1.0.17.tar.bz2
sha256=VERIFY

build() {
    ./configure --prefix=/usr
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
