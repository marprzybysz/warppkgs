pkgname=libmpdclient
pkgver=2.22
description="MPD client library — wymagana przez ncmpcpp i inne frontendy MPD"
arch=x86_64
license=BSD
deps=glibc
makedeps=gcc,meson,ninja,pkg-config
source=https://github.com/MusicPlayerDaemon/libmpdclient/archive/refs/tags/v2.22.tar.gz
sha256=VERIFY

build() {
    meson setup build --prefix=/usr --buildtype=release
    ninja -C build $MAKEFLAGS
}

package() {
    DESTDIR="$DESTDIR" ninja -C build install
}
