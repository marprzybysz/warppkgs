pkgname=ranger
pkgver=1.9.4
description="File manager TUI napisany w Pythonie — podgląd plików, vim keybindings"
arch=x86_64
license=GPL-3.0
deps=glibc,python3
makedeps=python3
source=https://github.com/ranger/ranger/archive/refs/tags/v1.9.4.tar.gz
sha256=VERIFY

build() {
    python3 setup.py build
}

package() {
    python3 setup.py install --root="$DESTDIR" --prefix=/usr --optimize=1
}
