pkgname=shared-mime-info
pkgver=2.4
description="Shared MIME-type database — wymagana przez GTK, Nautilus i wiele aplikacji"
arch=x86_64
license=GPL-2.0
deps=glibc,glib,libxml2
makedeps=gcc,meson,ninja,pkg-config,itstool,gettext
source=https://gitlab.freedesktop.org/xdg/shared-mime-info/-/archive/2.4/shared-mime-info-2.4.tar.gz
sha256=VERIFY

build() {
    meson setup build --prefix=/usr --buildtype=release -Dbuild-tests=false
    ninja -C build $MAKEFLAGS
}

package() {
    DESTDIR="$DESTDIR" ninja -C build install
}
