pkgname=vulkan-loader
pkgver=1.3.290
description="Khronos Vulkan ICD loader — wymagany przez wszystkie aplikacje Vulkan"
arch=x86_64
license=Apache-2.0
deps=glibc,libx11,libxcb,wayland
makedeps=gcc,cmake,ninja,pkg-config,python3,wayland-protocols
source=https://github.com/KhronosGroup/Vulkan-Loader/archive/refs/tags/v1.3.290.tar.gz
sha256=VERIFY

build() {
    cmake -B build -G Ninja \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr \
        -DVULKAN_HEADERS_INSTALL_DIR=/usr
    ninja -C build $MAKEFLAGS
}

package() {
    DESTDIR="$DESTDIR" ninja -C build install
}
