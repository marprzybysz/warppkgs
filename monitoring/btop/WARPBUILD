pkgname=btop
pkgver=1.4.0
description="Nowoczesny monitor zasobów — CPU, RAM, sieć, dysk w TUI"
arch=x86_64
license=Apache-2.0
deps=glibc,libcap
makedeps=gcc,cmake,ninja
source=https://github.com/aristocratos/btop/releases/download/v1.4.0/btop-v1.4.0.tar.bz2
sha256=VERIFY

build() {
    cmake -B build -G Ninja \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr
    ninja -C build $MAKEFLAGS
}

package() {
    DESTDIR="$DESTDIR" ninja -C build install
}
