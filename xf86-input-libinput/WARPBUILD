pkgname=xf86-input-libinput
pkgver=1.4.0
description="Xorg input driver using libinput (myszka, klawiatura, touchpad)"
arch=x86_64
license=MIT
deps=glibc,xorg-server,libinput
makedeps=gcc,make,pkg-config,autoconf,automake,libtool,xorg-server
source=https://xorg.freedesktop.org/releases/individual/driver/xf86-input-libinput-1.4.0.tar.xz
sha256=VERIFY

build() {
    ./configure --prefix=/usr
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
