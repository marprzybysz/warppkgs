pkgname=coreutils
pkgver=9.5
description="GNU core utilities (ls, cp, mv, cat, etc.)"
arch=x86_64
license=GPL-3.0
deps=glibc,acl,attr,libcap
makedeps=gcc,make
source=https://ftp.gnu.org/gnu/coreutils/coreutils-9.5.tar.xz
sha256=cd328edeac92f6a665de9f323c93b712af1858bc2e0d88f3f7100469571571a0

build() {
    ./configure --prefix=/usr --enable-no-install-program=kill,uptime
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
