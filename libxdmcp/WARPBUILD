pkgname=libxdmcp
pkgver=1.1.5
description="X Display Manager Control Protocol library — wymagana przez Xorg server"
arch=x86_64
license=MIT
deps=glibc,xorg-util-macros
makedeps=gcc,make,pkg-config,autoconf,automake,libtool
source=https://xorg.freedesktop.org/releases/individual/lib/libXdmcp-1.1.5.tar.xz
sha256=VERIFY

build() {
    ./configure --prefix=/usr
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
