pkgname=fastfetch
pkgver=2.34.0
description="Fast system information tool written in C"
arch=x86_64
license=MIT
deps=glibc,gcc-runtime
makedeps=gcc,g++,cmake,ninja,pkg-config
source=https://github.com/fastfetch-cli/fastfetch/archive/refs/tags/2.34.0.tar.gz
sha256=

build() {
    cmake -B build -G Ninja \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr
    ninja -C build
}

package() {
    DESTDIR="$DESTDIR" ninja -C build install
}
