pkgname=libXft
pkgver=2.3.8
description="X FreeType interface library"
arch=x86_64
license=MIT
deps=glibc,libX11,libXrender,freetype,fontconfig
makedeps=gcc,make,pkg-config
source=https://xorg.freedesktop.org/archive/individual/lib/libXft-2.3.8.tar.xz
sha256=

build() {
    ./configure --prefix=/usr --disable-static
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
