pkgname=libpng
pkgver=1.6.44
description="PNG reference library"
arch=x86_64
license=Libpng
deps=glibc,zlib
makedeps=gcc,make
source=https://downloads.sourceforge.net/libpng/libpng-1.6.44.tar.xz
sha256=

build() {
    ./configure --prefix=/usr --disable-static
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
