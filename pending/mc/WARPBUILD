pkgname=mc
pkgver=4.8.32
description="Midnight Commander — visual file manager"
arch=x86_64
license=GPL-3.0
deps=glibc,ncurses,glib
makedeps=gcc,make,pkg-config
source=https://github.com/MidnightCommander/mc/releases/download/4.8.32/mc-4.8.32.tar.xz
sha256=

build() {
    ./configure --prefix=/usr      \
                --sysconfdir=/etc  \
                --enable-charset   \
                --with-screen=ncurses
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
