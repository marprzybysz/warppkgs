pkgname=freetype
pkgver=2.13.3
description="Font rendering library"
arch=x86_64
license=FTL
deps=glibc,zlib,bzip2,libpng
makedeps=gcc,make,pkg-config
source=https://downloads.sourceforge.net/freetype/freetype-2.13.3.tar.xz
sha256=

build() {
    ./configure --prefix=/usr     \
                --enable-freetype-config \
                --disable-static
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
