pkgname=libXau
pkgver=1.0.11
description="X11 Authorization Protocol library"
arch=x86_64
license=MIT
deps=glibc,xorgproto
makedeps=gcc,make,pkg-config
source=https://xorg.freedesktop.org/archive/individual/lib/libXau-1.0.11.tar.xz
sha256=

build() {
    ./configure --prefix=/usr --disable-static
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
