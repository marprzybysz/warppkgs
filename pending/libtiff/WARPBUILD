pkgname=libtiff
pkgver=4.7.0
description="TIFF image format library"
arch=x86_64
license=MIT
deps=glibc,zlib,libjpeg-turbo,xz-utils,zstd
makedeps=gcc,cmake,ninja,pkg-config
source=https://download.osgeo.org/libtiff/tiff-4.7.0.tar.gz
sha256=

build() {
    cmake -B build -G Ninja        \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr
    ninja -C build
}

package() {
    DESTDIR="$DESTDIR" ninja -C build install
}
