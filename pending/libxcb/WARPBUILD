pkgname=libxcb
pkgver=1.17.0
description="X11 C Bindings library"
arch=x86_64
license=MIT
deps=glibc,xcb-proto,libXau,libXdmcp
makedeps=gcc,make,pkg-config,python3
source=https://xorg.freedesktop.org/archive/individual/lib/libxcb-1.17.0.tar.xz
sha256=

build() {
    ./configure --prefix=/usr --disable-static --without-doxygen
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
