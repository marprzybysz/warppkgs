pkgname=libXmu
pkgver=1.2.1
description="X11 miscellaneous utility library"
arch=x86_64
license=MIT
deps=glibc,libX11,libXext,libXt
makedeps=gcc,make,pkg-config
source=https://xorg.freedesktop.org/archive/individual/lib/libXmu-1.2.1.tar.xz
sha256=

build() {
    ./configure --prefix=/usr --disable-static
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
