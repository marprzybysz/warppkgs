pkgname=htop
pkgver=3.3.0
description="Interactive process viewer"
arch=x86_64
license=GPL-2.0
deps=glibc,ncurses
makedeps=gcc,make,pkg-config
source=https://github.com/htop-dev/htop/releases/download/3.3.0/htop-3.3.0.tar.xz
sha256=

build() {
    ./configure --prefix=/usr --enable-unicode
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
