pkgname=libXext
pkgver=1.3.6
description="X11 miscellaneous extensions library"
arch=x86_64
license=MIT
deps=glibc,libX11
makedeps=gcc,make,pkg-config
source=https://xorg.freedesktop.org/archive/individual/lib/libXext-1.3.6.tar.xz
sha256=

build() {
    ./configure --prefix=/usr --disable-static
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
