pkgname=fontconfig
pkgver=2.15.0
description="Font configuration and customization library"
arch=x86_64
license=MIT
deps=glibc,freetype,expat,util-linux
makedeps=gcc,make,pkg-config,gperf
source=https://www.freedesktop.org/software/fontconfig/release/fontconfig-2.15.0.tar.xz
sha256=

build() {
    ./configure --prefix=/usr     \
                --sysconfdir=/etc \
                --localstatedir=/var \
                --disable-static
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
