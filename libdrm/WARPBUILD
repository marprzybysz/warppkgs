pkgname=libdrm
pkgver=2.4.123
description="Userspace interface to kernel DRM services"
arch=x86_64
license=MIT
deps=glibc
makedeps=gcc,meson,ninja,pkg-config,python3
source=https://dri.freedesktop.org/libdrm/libdrm-2.4.123.tar.xz
sha256=VERIFY

build() {
    meson setup build \
        --prefix=/usr \
        --buildtype=release \
        -Dudev=false \
        -Dtests=false
    ninja -C build $MAKEFLAGS
}

package() {
    DESTDIR="$DESTDIR" ninja -C build install
}
