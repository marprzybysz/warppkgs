pkgname=c-ares
pkgver=1.34.2
description="Asynchronous DNS resolver library (używana przez Node.js)"
arch=x86_64
license=MIT
deps=glibc
makedeps=gcc,cmake,ninja
source=https://github.com/c-ares/c-ares/releases/download/v1.34.2/c-ares-1.34.2.tar.gz
sha256=VERIFY

build() {
    cmake -B build -G Ninja \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr
    ninja -C build $MAKEFLAGS
}

package() {
    DESTDIR="$DESTDIR" ninja -C build install
}
