pkgname=bash
pkgver=5.2.32
description="GNU Bourne-Again Shell"
arch=x86_64
license=GPL-3.0
deps=glibc,readline,ncurses
makedeps=gcc,make
source=https://ftp.gnu.org/gnu/bash/bash-5.2.32.tar.gz
sha256=d3ef80d2b67d8cbbe4d3265c63a72c46f9b278ead6e0e06a61571c8571418a17

build() {
    ./configure --prefix=/usr             \
                --without-bash-malloc     \
                --with-installed-readline
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
