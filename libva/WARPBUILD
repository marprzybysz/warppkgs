pkgname=libva
pkgver=2.22.0
description="Video Acceleration API (hardware decode/encode)"
arch=x86_64
license=MIT
deps=glibc,mesa,libdrm,libx11,libxext
makedeps=gcc,meson,ninja,pkg-config
source=https://github.com/intel/libva/releases/download/2.22.0/libva-2.22.0.tar.bz2
sha256=VERIFY

build() {
    meson setup build \
        --prefix=/usr \
        --buildtype=release \
        -Dwith_x11=yes \
        -Dwith_wayland=no
    ninja -C build $MAKEFLAGS
}

package() {
    DESTDIR="$DESTDIR" ninja -C build install
}
