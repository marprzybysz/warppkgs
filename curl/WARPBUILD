pkgname=curl
pkgver=8.13.0
description="URL transfer library and tool"
arch=x86_64
license=MIT
deps=glibc,openssl,zlib
makedeps=gcc,make,pkg-config
source=https://curl.se/download/curl-8.13.0.tar.xz
sha256=VERIFY

build() {
    ./configure --prefix=/usr         \
                --with-openssl        \
                --enable-threaded-resolver \
                --disable-static
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
