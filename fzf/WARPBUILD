pkgname=fzf
pkgver=0.55.0
description="Command-line fuzzy finder — interaktywne wyszukiwanie w listach i plikach"
arch=x86_64
license=MIT
deps=glibc
makedeps=go
source=https://github.com/junegunn/fzf/archive/refs/tags/v0.55.0.tar.gz
sha256=VERIFY

build() {
    go build -ldflags="-s -w" -o fzf .
}

package() {
    install -Dm755 fzf "$DESTDIR/usr/bin/fzf"
    install -Dm644 shell/completion.bash "$DESTDIR/usr/share/bash-completion/completions/fzf"
    install -Dm644 shell/completion.zsh  "$DESTDIR/usr/share/zsh/site-functions/_fzf"
    install -Dm644 shell/completion.fish "$DESTDIR/usr/share/fish/vendor_completions.d/fzf.fish"
}
