pkgname=fontconfig
pkgver=2.15.0
description="Font configuration and customization library"
arch=x86_64
license=MIT
deps=glibc,freetype,expat
makedeps=gcc,make,pkg-config,gperf,python3
source=https://www.freedesktop.org/software/fontconfig/release/fontconfig-2.15.0.tar.xz
sha256=VERIFY

build() {
    ./configure --prefix=/usr \
                --sysconfdir=/etc \
                --localstatedir=/var \
                --disable-docs \
                --disable-static
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
