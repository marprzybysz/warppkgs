pkgname=qt6-tools
pkgver=6.8.1
description="Qt6 developer tools (uic, rcc, lupdate, lrelease)"
arch=x86_64
license=LGPL-3.0
deps=qt6-base,qt6-declarative
makedeps=gcc,cmake,ninja
source=https://download.qt.io/official_releases/qt/6.8/6.8.1/submodules/qttools-everywhere-src-6.8.1.tar.xz
sha256=VERIFY

build() {
    cmake -GNinja \
          -DCMAKE_INSTALL_PREFIX=/usr \
          -DCMAKE_BUILD_TYPE=Release \
          -DQT_BUILD_EXAMPLES=OFF \
          -DQT_BUILD_TESTS=OFF \
          -B build
    ninja -C build $MAKEFLAGS
}

package() {
    DESTDIR="$DESTDIR" ninja -C build install
}
