pkgname=kwin
pkgver=6.2.5
description="KDE window manager (Wayland + X11)"
arch=x86_64
license=GPL-2.0
deps=glibc,qt6-base,qt6-declarative,qt6-wayland,kconfig,kcoreaddons,kwindowsystem,kdbusaddons,kglobalaccel,libxkbcommon,wayland,libinput,mesa,libdrm,libxcb
makedeps=gcc,cmake,ninja,extra-cmake-modules,qt6-tools,wayland-protocols,knotifications,kiconthemes
source=https://download.kde.org/stable/plasma/6.2.5/kwin-6.2.5.tar.xz
sha256=VERIFY

build() {
    cmake -GNinja \
          -DCMAKE_INSTALL_PREFIX=/usr \
          -DCMAKE_BUILD_TYPE=Release \
          -DBUILD_TESTING=OFF \
          -B build
    ninja -C build $MAKEFLAGS
}

package() {
    DESTDIR="$DESTDIR" ninja -C build install
}
