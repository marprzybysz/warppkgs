pkgname=plasma-workspace
pkgver=6.2.5
description="KDE Plasma desktop workspace (panel, taskbar, systray)"
arch=x86_64
license=GPL-2.0
deps=glibc,qt6-base,qt6-declarative,qt6-svg,qt6-wayland,kwin,kconfig,kcoreaddons,kwindowsystem,kiconthemes,kservice,kio,knotifications,kpackage,polkit,elogind,dbus,wayland,fontconfig,freetype
makedeps=gcc,cmake,ninja,extra-cmake-modules,qt6-tools,wayland-protocols
source=https://download.kde.org/stable/plasma/6.2.5/plasma-workspace-6.2.5.tar.xz
sha256=VERIFY

build() {
    cmake -GNinja \
          -DCMAKE_INSTALL_PREFIX=/usr \
          -DCMAKE_BUILD_TYPE=Release \
          -DBUILD_TESTING=OFF \
          -B build
    ninja -C build $MAKEFLAGS
}

package() {
    DESTDIR="$DESTDIR" ninja -C build install
}
