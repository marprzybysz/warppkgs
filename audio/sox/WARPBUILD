pkgname=sox
pkgver=14.4.2
description="Swiss Army Knife audio — konwersja formatów, efekty, play/rec z CLI"
arch=x86_64
license=GPL-2.0
deps=glibc,alsa-lib,libvorbis,flac,libmad,libpng
makedeps=gcc,make,pkg-config,autoconf,automake
source=https://sourceforge.net/projects/sox/files/sox/14.4.2/sox-14.4.2.tar.bz2
sha256=VERIFY

build() {
    ./configure --prefix=/usr
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
