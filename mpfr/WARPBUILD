pkgname=mpfr
pkgver=4.2.1
description="Multiple-precision floating-point library"
arch=x86_64
license=LGPL-3.0
deps=glibc,gmp
makedeps=gcc,make
source=https://ftp.gnu.org/gnu/mpfr/mpfr-4.2.1.tar.xz
sha256=277807353a6726978996945af13e52829e3abd7a9a5b7fb2793894e18f1fcbb2

build() {
    ./configure --prefix=/usr --disable-static --enable-thread-safe
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
