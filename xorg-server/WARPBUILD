pkgname=xorg-server
pkgver=21.1.14
description="Xorg display server"
arch=x86_64
license=MIT
deps=glibc,libxcb,libx11,libxext,libxrender,libxfixes,libxcomposite,libxdamage,mesa,pixman,dbus,eudev,libinput,libxkbcommon,openssl,xkeyboard-config
makedeps=gcc,meson,ninja,pkg-config,python3,xcb-proto,xkeyboard-config
source=https://xorg.freedesktop.org/releases/individual/xserver/xorg-server-21.1.14.tar.xz
sha256=VERIFY

build() {
    meson setup build \
        --prefix=/usr \
        --buildtype=release \
        -Dxwayland=false \
        -Dxephyr=false \
        -Dxvfb=true \
        -Dglamor=true \
        -Dudev=true \
        -Dsystemd_logind=false
    ninja -C build $MAKEFLAGS
}

package() {
    DESTDIR="$DESTDIR" ninja -C build install
}
