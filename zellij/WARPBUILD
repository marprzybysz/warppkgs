pkgname=zellij
pkgver=0.41.0
description="Terminal multiplexer — nowoczesny tmux z layoutami, pluginami i WebAssembly"
arch=x86_64
license=MIT
deps=glibc
makedeps=rust
source=https://github.com/zellij-org/zellij/archive/refs/tags/v0.41.0.tar.gz
sha256=VERIFY

build() {
    cargo build --release --locked
}

package() {
    install -Dm755 target/release/zellij "$DESTDIR/usr/bin/zellij"
}
