pkgname=zen-browser
pkgver=1.0.2-b.5
description="Zen Browser — Firefox-based browser focused on privacy and clean UI"
arch=x86_64
license=MPL-2.0
deps=glibc,gtk3,dbus,glib,libxkbcommon,libx11,libxext,libxcomposite,libxdamage,libxfixes,alsa-lib,pipewire,fontconfig,freetype,harfbuzz,nss,zlib,bzip2,libjpeg-turbo,libpng,at-spi2-core
makedeps=rust,clang,python3,nodejs,nasm,cbindgen,autoconf,pkg-config,unzip
source=https://github.com/zen-browser/desktop/archive/refs/tags/1.0.2-b.5.tar.gz
sha256=VERIFY

build() {
    # Zen używa narzędzia surfer do pobrania Firefox source + aplikacji patchy
    npm ci
    export ZEN_RELEASE=1
    export SURFER_COMPAT=false
    ./scripts/download-surfer.sh || npm run surfer -- download
    npm run surfer -- ci --brand release
}

package() {
    # Binaria trafiają do obj-*/dist/bin/
    _distdir=$(find . -maxdepth 3 -name "bin" -path "*/dist/bin" | head -1)
    install -dm755 "$DESTDIR/usr/lib/zen-browser"
    cp -r "$_distdir"/. "$DESTDIR/usr/lib/zen-browser/"
    ln -sf /usr/lib/zen-browser/zen "$DESTDIR/usr/bin/zen-browser"

    install -Dm644 /dev/stdin "$DESTDIR/usr/share/applications/zen-browser.desktop" << 'EOF'
[Desktop Entry]
Name=Zen Browser
Comment=Experience tranquillity while browsing the web
Exec=zen-browser %u
Terminal=false
Type=Application
Categories=Network;WebBrowser;
MimeType=text/html;text/xml;application/xhtml+xml;
Icon=zen-browser
EOF
}
