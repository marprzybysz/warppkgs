pkgname=libx11
pkgver=1.8.10
description="X11 client-side library"
arch=x86_64
license=MIT
deps=glibc,libxcb
makedeps=gcc,make,pkgconf,xorg-util-macros
source=https://xorg.freedesktop.org/releases/individual/lib/libX11-1.8.10.tar.xz
sha256=5094d1f0fcc1828cb1696d0d39d9e866ae32520c54d01f618f1a3c1e30c2085c

build() {
    ./configure --prefix=/usr --disable-static
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
