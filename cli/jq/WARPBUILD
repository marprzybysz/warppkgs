pkgname=jq
pkgver=1.7.1
description="Lightweight JSON processor — formatowanie i filtrowanie JSON w CLI"
arch=x86_64
license=MIT
deps=glibc,oniguruma
makedeps=gcc,make,autoconf,automake,libtool,pkg-config
source=https://github.com/jqlang/jq/releases/download/jq-1.7.1/jq-1.7.1.tar.gz
sha256=VERIFY

build() {
    ./configure --prefix=/usr \
                --disable-static \
                --with-oniguruma
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
