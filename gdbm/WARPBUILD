pkgname=gdbm
pkgver=1.24
description="GNU database manager"
arch=x86_64
license=GPL-3.0
deps=glibc,readline
makedeps=gcc,make
source=https://ftp.gnu.org/gnu/gdbm/gdbm-1.24.tar.gz
sha256=695e9827fdf763513f133910bc7e6cfdb9187943a4fec943e57449723d2b8dbf

build() {
    ./configure --prefix=/usr --disable-static --enable-libgdbm-compat
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
