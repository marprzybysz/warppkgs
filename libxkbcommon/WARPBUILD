pkgname=libxkbcommon
pkgver=1.7.0
description="Keyboard description library"
arch=x86_64
license=MIT
deps=glibc,libxcb
makedeps=gcc,meson,ninja,pkg-config,python3,xkeyboard-config
source=https://xkbcommon.org/download/libxkbcommon-1.7.0.tar.xz
sha256=VERIFY

build() {
    meson setup build \
        --prefix=/usr \
        --buildtype=release \
        -Denable-docs=false \
        -Denable-wayland=true \
        -Denable-x11=true
    ninja -C build $MAKEFLAGS
}

package() {
    DESTDIR="$DESTDIR" ninja -C build install
}
