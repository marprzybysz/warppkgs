pkgname=libxml2
pkgver=2.13.4
description="XML parsing library (używana przez PHP, Crystal, wiele innych)"
arch=x86_64
license=MIT
deps=glibc,zlib,xz-utils
makedeps=gcc,make,pkg-config,autoconf,automake,libtool,python3
source=https://download.gnome.org/sources/libxml2/2.13/libxml2-2.13.4.tar.xz
sha256=VERIFY

build() {
    ./configure --prefix=/usr --disable-static --with-history
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
