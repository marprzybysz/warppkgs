pkgname=libmnl
pkgver=1.0.5
description="Minimalistic Netlink library — wymagana przez iptables i iproute2"
arch=x86_64
license=LGPL-2.1
deps=glibc
makedeps=gcc,make,autoconf,automake,libtool
source=https://netfilter.org/projects/libmnl/files/libmnl-1.0.5.tar.bz2
sha256=VERIFY

build() {
    ./configure --prefix=/usr
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
