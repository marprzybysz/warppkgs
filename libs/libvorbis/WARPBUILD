pkgname=libvorbis
pkgver=1.3.7
description="Vorbis audio codec library (OGG)"
arch=x86_64
license=BSD
deps=glibc,libogg
makedeps=gcc,make,autoconf,automake,libtool
source=https://downloads.xiph.org/releases/vorbis/libvorbis-1.3.7.tar.xz
sha256=VERIFY

build() {
    ./configure --prefix=/usr --disable-static
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
