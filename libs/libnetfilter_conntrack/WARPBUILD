pkgname=libnetfilter_conntrack
pkgver=1.0.9
description="Netfilter connection tracking library — wymagana przez iptables"
arch=x86_64
license=GPL-2.0
deps=glibc,libmnl,libnfnetlink
makedeps=gcc,make,autoconf,automake,libtool,pkg-config
source=https://netfilter.org/projects/libnetfilter_conntrack/files/libnetfilter_conntrack-1.0.9.tar.bz2
sha256=VERIFY

build() {
    ./configure --prefix=/usr
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
