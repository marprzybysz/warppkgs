pkgname=libadwaita
pkgver=1.6.0
description="GNOME HIG widgets for GTK4"
arch=x86_64
license=LGPL-2.1
deps=glibc,gtk4,glib
makedeps=gcc,meson,ninja,pkg-config,python3,gobject-introspection,vala
source=https://ftp.gnome.org/pub/gnome/sources/libadwaita/1.6/libadwaita-1.6.0.tar.xz
sha256=VERIFY

build() {
    meson setup build \
        --prefix=/usr \
        --buildtype=release \
        -Dintrospection=disabled \
        -Dvapi=false \
        -Dexamples=false \
        -Dtests=false
    ninja -C build $MAKEFLAGS
}

package() {
    DESTDIR="$DESTDIR" ninja -C build install
}
