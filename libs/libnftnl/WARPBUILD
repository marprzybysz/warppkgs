pkgname=libnftnl
pkgver=1.2.7
description="nftables netlink library — wymagana przez iptables"
arch=x86_64
license=GPL-2.0
deps=glibc,libmnl
makedeps=gcc,make,autoconf,automake,libtool,pkg-config
source=https://netfilter.org/projects/libnftnl/files/libnftnl-1.2.7.tar.xz
sha256=VERIFY

build() {
    ./configure --prefix=/usr
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
