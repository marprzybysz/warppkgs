pkgname=libxdamage
pkgver=1.1.6
description="X Damage extension library"
arch=x86_64
license=MIT
deps=glibc,libx11,libxfixes
makedeps=gcc,make,pkg-config
source=https://xorg.freedesktop.org/releases/individual/lib/libXdamage-1.1.6.tar.xz
sha256=VERIFY

build() {
    ./configure --prefix=/usr --disable-static
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
