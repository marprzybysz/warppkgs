pkgname=libxtst
pkgver=1.2.4
description="X Test extension library — wymagana przez OpenJDK i narzędzia automatyzacji"
arch=x86_64
license=MIT
deps=glibc,libx11,libxext,libxi
makedeps=gcc,make,pkg-config,autoconf,automake,libtool
source=https://xorg.freedesktop.org/releases/individual/lib/libXtst-1.2.4.tar.xz
sha256=VERIFY

build() {
    ./configure --prefix=/usr
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
