pkgname=libxcomposite
pkgver=0.4.6
description="X Composite extension library"
arch=x86_64
license=MIT
deps=glibc,libx11,libxfixes
makedeps=gcc,make,pkg-config
source=https://xorg.freedesktop.org/releases/individual/lib/libXcomposite-0.4.6.tar.xz
sha256=VERIFY

build() {
    ./configure --prefix=/usr --disable-static
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
