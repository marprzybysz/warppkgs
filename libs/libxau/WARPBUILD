pkgname=libxau
pkgver=1.0.11
description="X11 authorization library — wymagana przez libxcb i Xorg"
arch=x86_64
license=MIT
deps=glibc,xorg-util-macros
makedeps=gcc,make,pkg-config,autoconf,automake,libtool
source=https://xorg.freedesktop.org/releases/individual/lib/libXau-1.0.11.tar.xz
sha256=VERIFY

build() {
    ./configure --prefix=/usr
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
