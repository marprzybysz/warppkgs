pkgname=libyaml
pkgver=0.2.5
description="YAML parser i emitter (używana przez Ruby, Crystal)"
arch=x86_64
license=MIT
deps=glibc
makedeps=gcc,make,autoconf,automake,libtool
source=https://pyyaml.org/download/libyaml/yaml-0.2.5.tar.gz
sha256=VERIFY

build() {
    ./configure --prefix=/usr --disable-static
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
