pkgname=xkeyboard-config
pkgver=2.43
description="X keyboard configuration database"
arch=x86_64
license=MIT
deps=
makedeps=meson,ninja,python3,gettext
source=https://xorg.freedesktop.org/releases/individual/data/xkeyboard-config/xkeyboard-config-2.43.tar.xz
sha256=VERIFY

build() {
    meson setup build --prefix=/usr --buildtype=release
    ninja -C build $MAKEFLAGS
}

package() {
    DESTDIR="$DESTDIR" ninja -C build install
}
