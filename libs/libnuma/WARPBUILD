pkgname=libnuma
pkgver=2.0.18
description="NUMA (Non-Uniform Memory Access) library — wymagana przez GHC i niektóre DB"
arch=x86_64
license=LGPL-2.1
deps=glibc
makedeps=gcc,make,autoconf,automake,libtool
source=https://github.com/numactl/numactl/releases/download/v2.0.18/numactl-2.0.18.tar.gz
sha256=VERIFY

build() {
    ./configure --prefix=/usr
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
