pkgname=lua
pkgver=5.4.7
description="Lightweight scripting language"
arch=x86_64
license=MIT
deps=glibc,readline
makedeps=gcc,make
source=https://www.lua.org/ftp/lua-5.4.7.tar.gz
sha256=VERIFY

build() {
    make $MAKEFLAGS INSTALL_TOP=/usr linux
}

package() {
    make INSTALL_TOP="$DESTDIR/usr" install
}
