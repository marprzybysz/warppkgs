pkgname=mpv
pkgver=0.39.0
description="Minimalist media player"
arch=x86_64
license=GPL-2.0
deps=glibc,ffmpeg,alsa-lib,libx11,libxext,libxrandr,wayland,mesa,libva,libxkbcommon,freetype,fontconfig,lua,zlib
makedeps=gcc,meson,ninja,pkg-config,python3
source=https://github.com/mpv-player/mpv/archive/refs/tags/v0.39.0.tar.gz
sha256=VERIFY

build() {
    meson setup build \
        --prefix=/usr \
        --buildtype=release \
        -Dlibmpv=true \
        -Dcplayer=true \
        -Ddvdnav=disabled \
        -Dcdda=disabled \
        -Ddvbin=disabled
    ninja -C build $MAKEFLAGS
}

package() {
    DESTDIR="$DESTDIR" ninja -C build install
}
