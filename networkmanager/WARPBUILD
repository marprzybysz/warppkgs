pkgname=networkmanager
pkgver=1.50.0
description="Network connection manager"
arch=x86_64
license=GPL-2.0
deps=glibc,glib,dbus,eudev,libnl,libndp,openssl,curl,polkit,elogind
makedeps=gcc,meson,ninja,pkg-config,python3,gobject-introspection,vala
source=https://gitlab.freedesktop.org/NetworkManager/NetworkManager/-/archive/1.50.0/NetworkManager-1.50.0.tar.gz
sha256=VERIFY

build() {
    meson setup build \
        --prefix=/usr \
        --sysconfdir=/etc \
        --localstatedir=/var \
        --buildtype=release \
        -Dsystemd_journal=false \
        -Dsession_tracking=elogind \
        -Dselinux=false \
        -Dqt=false \
        -Ddocs=false \
        -Dtests=no \
        -Dwifi=true \
        -Dwext=true \
        -Dppp=false
    ninja -C build $MAKEFLAGS
}

package() {
    DESTDIR="$DESTDIR" ninja -C build install
}
