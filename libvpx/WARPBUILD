pkgname=libvpx
pkgver=1.14.1
description="VP8/VP9 video codec library — wymagana przez ffmpeg i przeglądarki"
arch=x86_64
license=BSD
deps=glibc
makedeps=gcc,make,yasm,perl
source=https://github.com/webmproject/libvpx/archive/refs/tags/v1.14.1.tar.gz
sha256=VERIFY

build() {
    ./configure --prefix=/usr \
                --enable-shared \
                --disable-static \
                --enable-vp8 \
                --enable-vp9
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
