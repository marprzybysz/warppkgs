pkgname=runc
pkgver=1.2.0
description="OCI container runtime — niskopoziomowy runtime kontenerów"
arch=x86_64
license=Apache-2.0
deps=glibc,libseccomp
makedeps=go,make,pkg-config
source=https://github.com/opencontainers/runc/archive/refs/tags/v1.2.0.tar.gz
sha256=VERIFY

build() {
    make BUILDTAGS="seccomp" $MAKEFLAGS
}

package() {
    install -Dm755 runc "$DESTDIR/usr/bin/runc"
}
