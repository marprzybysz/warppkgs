pkgname=openssl
pkgver=3.5.0
description="TLS/SSL and crypto library"
arch=x86_64
license=Apache-2.0
deps=glibc,zlib
makedeps=gcc,make,perl
source=https://github.com/openssl/openssl/releases/download/openssl-3.5.0/openssl-3.5.0.tar.gz
sha256=VERIFY

build() {
    ./config --prefix=/usr         \
             --openssldir=/etc/ssl \
             --libdir=lib          \
             shared zlib-dynamic
    make $MAKEFLAGS
}

package() {
    make DESTDIR="$DESTDIR" install
}
